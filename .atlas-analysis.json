  "keyFeatures": [
    "Reference-free, reference-based, source-based, query-based, and pairwise text quality metrics",
    "Multi-language support (English, Japanese, German, Chinese)",
    "Text augmentation for robustness testing (gender, typos, rephrasing)",
    "Interactive visualizations (scatter plots, histograms)",
    "Integration with OpenAI, Anthropic, Gemini, and other LLM providers",
    "Custom metric creation with LLM-based evaluators",
    "Built-in support for unit testing, monitoring, and guardrails"
  ],
